generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://gentrack:gentrack123@localhost:5432/gentrack"
}

// ─── ENUMS ───────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  COMMERCIAL_AGENT
  PROCUREMENT_AGENT
  PHASE_SUPERVISOR
  OPERATOR
  QC_DELIVERY_AGENT
}

enum EnclosureType {
  STANDARD
  INSONORISE
}

enum ControlType {
  MANUEL
  AUTO
  INVERSEUR_SEPARE
}

enum EquipmentCategory {
  MOTEUR
  ALTERNATEUR
  ATS
  BATTERIE
  CARTE_COMMANDE
  CHARGEUR
}

enum OrderStatus {
  PENDING
  IN_PRODUCTION
  TESTING
  QC
  DELIVERED
  ARCHIVED
}

enum PhaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum MachineStatus {
  OPERATIONAL
  EN_PANNE
}

// ─── USERS ───────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phaseEntries     PhaseEntry[]
  supervisedPhases ProductionPhase[] @relation("PhaseSupervisor")
}

// ─── SERIAL NUMBER CONFIG ─────────────────────────────

model SerialConfig {
  id          String   @id @default(cuid())
  prefix      String
  separator   String   @default("-")
  includeYear Boolean  @default(true)
  padLength   Int      @default(4)
  lastNumber  Int      @default(0)
  lastYear    Int      @default(0)
  updatedAt   DateTime @updatedAt
}

// ─── EQUIPMENT CATALOG (admin managed) ───────────────

model EquipmentBrand {
  id        String            @id @default(cuid())
  name      String
  category  EquipmentCategory
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())

  models    EquipmentModel[]

  @@unique([name, category])
}

model EquipmentModel {
  id        String   @id @default(cuid())
  name      String
  minKva    Float?
  maxKva    Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  brand      EquipmentBrand  @relation(fields: [brandId], references: [id])
  brandId    String

  components EngineComponent[]
}

// ─── PRODUCTION ORDER ────────────────────────────────

model ProductionOrder {
  id            String        @id @default(cuid())
  serialNumber  String        @unique
  qrCode        String?
  enclosureType EnclosureType
  controlType   ControlType
  clientName    String
  clientPhone   String?
  clientEmail   String?
  requirements  String?
  status        OrderStatus   @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deliveredAt   DateTime?

  components       EngineComponent[]
  productionPhases ProductionPhase[]
  warranty         Warranty?
}

// ─── ENGINE COMPONENTS ────────────────────────────────

model EngineComponent {
  id           String   @id @default(cuid())
  serialNumber String
  notes        String?
  createdAt    DateTime @default(now())

  order            ProductionOrder @relation(fields: [orderId], references: [id])
  orderId          String

  equipmentModel   EquipmentModel? @relation(fields: [equipmentModelId], references: [id])
  equipmentModelId String?
}

// ─── MACHINES ────────────────────────────────────────

model Machine {
  id           String        @id @default(cuid())
  name         String
  phase        Int
  status       MachineStatus @default(OPERATIONAL)
  minOperators Int           @default(1)
  maxOperators Int           @default(2)
  notes        String?
  updatedAt    DateTime      @updatedAt

  phaseEntries PhaseEntry[]
}

// ─── PRODUCTION PHASES ───────────────────────────────

model ProductionPhase {
  id           String      @id @default(cuid())
  phaseNumber  Int
  status       PhaseStatus @default(PENDING)
  startedAt    DateTime?
  completedAt  DateTime?
  notes        String?
  delayMinutes Int?

  order        ProductionOrder @relation(fields: [orderId], references: [id])
  orderId      String

  supervisor   User?  @relation("PhaseSupervisor", fields: [supervisorId], references: [id])
  supervisorId String?

  entries      PhaseEntry[]

  @@unique([orderId, phaseNumber])
}

// ─── PHASE ENTRIES ────────────────────────────────────

model PhaseEntry {
  id         String   @id @default(cuid())
  action     String
  notes      String?
  createdAt  DateTime @default(now())

  phase      ProductionPhase @relation(fields: [phaseId], references: [id])
  phaseId    String

  operator   User   @relation(fields: [operatorId], references: [id])
  operatorId String

  machine    Machine? @relation(fields: [machineId], references: [id])
  machineId  String?
}

// ─── WARRANTY ────────────────────────────────────────

model Warranty {
  id         String   @id @default(cuid())
  startDate  DateTime
  endDate    DateTime
  conditions String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  order   ProductionOrder @relation(fields: [orderId], references: [id])
  orderId String          @unique
}

// ─── DOCUMENT SETTINGS ───────────────────────────────


model DocumentSettings {
  id                String   @id @default(cuid())
  companyName       String
  logoUrl           String?
  headerText        String?
  footerText        String?
  warrantyMonths    Int      @default(12)
  updatedAt         DateTime @updatedAt
}